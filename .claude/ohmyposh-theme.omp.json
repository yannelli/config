{
  "$schema": 
  "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json", 
  "version": 4, "final_space": true, "streaming": 5000, "async": true, "upgrade": 
  {
    "source": "cdn", "auto": false, "notice": true
  },
  "maps": { "user_name": { "root": "root \udb85\udda7", "ryanyannelli": "Ryan"
    }
  },
  "tooltips_action": "replace", "tooltips": [ { "type": "git", "tips": ["git"], 
      "style": "diamond", "foreground": "p:ivory", "background": "p:claude-deep", 
      "leading_diamond": "", "trailing_diamond": "", "cache": {
        "duration": "1m", "strategy": "folder"
      },
      "template": "{{ .UpstreamIcon }} {{ .RepoName }} {{ .HEAD }}", "options": { 
        "fetch_status": true, "fetch_upstream_icon": true
      }
    }
  ], "shell_integration": true, "iterm_features": ["current_dir", "remote_host"], 
  "console_title_template": "{{ if .Env.POSH_CLAUDE_STATUS }}{{ $c := 
  .Env.POSH_CLAUDE_STATUS | fromJson }}\u2731 {{ $c.model.display_name }} \u2022 
  {{ .Folder }}{{ else }}{{ .Shell }} \u2022 {{ .Folder }}{{ end }}", "palette": 
  {
    "claude": "#D97757", "claude-deep": "#BF5B3F", "kraft": "#E8DCC4", "ivory": 
    "#F5F0E6", "ink": "#1F1F1E", "char": "#3D3D3A", "muted": "#8C8A82", "sage": 
    "#8BA888", "berry": "#A24E5A", "sky": "#6A8CAF"
  },
  "blocks": [ { "type": "prompt", "alignment": "left", "segments": [ { "type": 
          "os", "style": "diamond", "leading_diamond": "", "trailing_diamond": 
          "", "foreground": "p:ivory", "background": "p:ink", "template": " {{ 
          if .WSL }}WSL {{ end }}{{ .Icon }} "
        },
        { "type": "session", "style": "powerline", "powerline_symbol": "\ue0b0", 
          "foreground": "p:ink", "background": "p:kraft", "template": " {{ 
          .UserName }} {{ if .Root }} \udb85\udda7{{ end }}"
        },
        { "type": "path", "style": "powerline", "powerline_symbol": "\ue0b0", 
          "foreground": "p:ivory", "background": "p:claude", "max_width": 64, 
          "template": " {{ .Path }} ", "options": {
            "style": "agnoster_short", "max_depth": 3, "home_icon": "\uf015", 
            "folder_separator_icon": " \ue0b1 ", "hide_root_location": true
          }
        },
        { "type": "git", "style": "powerline", "powerline_symbol": "\ue0b0", 
          "foreground": "p:ink", "background": "p:kraft", "background_templates": 
          [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:claude-deep{{ end 
            }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:berry{{ end }}", "{{ if 
            gt .Ahead 0 }}p:sage{{ end }}", "{{ if gt .Behind 0 }}p:sky{{ end }}"
          ], "foreground_templates": [ "{{ if or (.Working.Changed) 
            (.Staging.Changed) }}p:ivory{{ end }}", "{{ if gt .Ahead 0 }}p:ink{{ 
            end }}", "{{ if gt .Behind 0 }}p:ivory{{ end }}"
          ], "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ 
          .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String 
          }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end 
          }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }} ",
          "options": { "fetch_status": true, "fetch_upstream_icon": true, 
            "untracked_modes": {
              "/Users/user/Projects/oh-my-posh/": "no"
            },
            "branch_icon": " ", "branch_behind_icon": "↓", "branch_ahead_icon": 
            "↑", "fetch_push_status": true, "fetch_user": true
          }
        },
        { "type": "npm", "style": "powerline", "powerline_symbol": "\ue0b0", 
          "foreground": "p:ivory", "background": "p:berry", "template": " \ue71e 
          {{ .Major }}.{{ .Minor }} "
        },
        { "type": "go", "style": "powerline", "powerline_symbol": "\ue0b0", 
          "foreground": "p:ivory", "background": "p:sky", "template": " \ue627 {{ 
          .Full }} "
        },
        { "type": "rust", "style": "powerline", "powerline_symbol": "\ue0b0", 
          "foreground": "p:ivory", "background": "p:claude-deep", "template": " 
          \ue7a8 {{ .Full }} "
        },
        { "type": "php", "style": "powerline", "powerline_symbol": "\ue0b0", 
          "foreground": "p:ivory", "background": "p:sky", "template": " \ue608 {{ 
          .Major }}.{{ .Minor }} "
        },
        { "type": "executiontime", "style": "powerline", "powerline_symbol": 
          "\ue0b0", "foreground": "p:ink", "background": "p:kraft", "template": " 
          \uf252 {{ .FormattedMs }} ", "options": {
            "threshold": 500, "style": "austin"
          }
        }
      ]
    },
    { "type": "prompt", "alignment": "right", "segments": [ { "type": "claude", 
          "style": "diamond", "leading_diamond": "\ue0b6", "trailing_diamond": 
          "\ue0b2", "foreground": "p:ivory", "background": "p:claude-deep", 
          "template": " \u2731 {{ .Model.DisplayName }} \ue0b3 {{ .TokenGauge }} 
          \ue0b3 {{ .FormattedCost }} ", "options": {
            "gauge_marked_char": "\u2731", "gauge_unmarked_char": "\u00b7"
          }
        }
      ]
    },
    { "type": "prompt", "alignment": "left", "newline": true, "segments": [ { 
          "type": "status", "style": "plain", "foreground": "p:sage", 
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:berry{{ end }}", "{{ if .Env.POSH_CLAUDE_STATUS 
            }}p:claude{{ end }}"
          ], "template": "✱ ", "options": { "always_enabled": true
          }
        },
        { "type": "text", "style": "plain", "foreground": "p:muted", "template": 
          "❯ "
        }
      ]
    }
  ], "transient_prompt": { "foreground": "p:claude", "background": "transparent", 
    "template": "✱ ❯ "
  },
  "secondary_prompt": { "foreground": "p:muted", "background": "transparent", 
    "template": "· ❯ "
  }
}
