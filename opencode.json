{
  "$schema": "https://opencode.ai/config.json",
  "shell": "zsh",
  "instructions": ["CLAUDE.md", "AGENTS.md", "CONTRIBUTING.md", "docs/guidelines.md", ".cursor/rules/*.md"],
  "disabled_providers": [],
  "permission": {
    "webfetch": "allow",
    "websearch": "allow"
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "glob": "allow",
        "list": "allow",
        "grep": "allow",
        "todowrite": "allow",
        "question": "allow",
        "read": "allow",
        "skill": "allow",
        "task": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "lsp":"allow",
        "bash": "allow",
        "external_directory": "ask",
        "doom_loop": "ask"
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "xai/grok-4.5",
      "permission": {
        "glob": "allow",
        "list": "allow",
        "grep": "allow",
        "read": "allow",
        "skill": "ask",
        "websearch": "allow",
        "webfetch": "allow",
        "lsp":"allow",
        "external_directory": "ask"
      }
    },
    "title": {
      "mode": "primary",
      "model": "openai/gpt-5.6-luna",
      "permission": "allow"
    },
    "summary": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-5",
      "permission":"allow"
    },
    "compaction": {
      "mode": "primary",
      "model": "openai/gpt-5.6-sol"
    },
    "general": {
      "mode": "all",
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "external_directory": "ask",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "skill": "allow",
        "task": "allow",
        "todowrite": "allow",
        "doom_loop": "ask",
        "question": "allow"
      }
    },
    "build": {
      "mode": "all",
      "permission": {
        "glob": "allow",
        "list": "allow",
        "grep": "allow",
        "read": "allow",
        "skill": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "lsp": "allow",
        "bash": "allow",
        "question": "allow",
        "edit": "allow",
        "task": "allow",
        "todowrite": "allow",
        "doom_loop": "ask",
        "external_directory": "ask"
      }
    }
  },
  "provider": {
    "cli": {
      "name": "CLI Proxy",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8317/v1"
      },
      "models": {
        "openai/gpt-5.6-terra": {
          "name": "GPT 5.6 Terra",
          "tool_call": true,
          "reasoning": true,
          "modalities": {
            "input": ["image", "text"]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
            }
          }
        },
        "openai/gpt-5.6-sol": {
          "name": "GPT 5.6 Sol",
          "tool_call": true,
          "reasoning": true,
          "modalities": {
            "input": ["image", "text"]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
            }
          }
        },
        "openai/gpt-5.6-luna": {
          "name": "GPT 5.6 Luna"
        },
        "z-ai/glm-5.2": {
          "name": "GLM 5.2",
          "tool_call": true,
          "reasoning": true,
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
            }
          }
        },
        "xai/grok-4.5": {
          "name": "Grok 4.5",
          "tool_call": true,
          "reasoning": true,
          "modalities": {
            "input": ["image", "text"]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
            }
          }
        },
        "anthropic/claude-fable-5": {
          "name": "Claude Fable 5",
          "reasoning": true,
          "tool_call": true,
        },
        "anthropic/claude-sonnet-5": {
          "name": "Claude Sonnet 5",
          "reasoning": true,
          "tool_call": true,
        },
        "anthropic/claude-opus-4-8": {
          "name": "Claude Opus 4.8",
          "reasoning": true,
          "tool_call": true,
        },
        "google/gemini-3.1-flash-lite": {
          "name": "Gemini 3.1 Flash Lite",
          "reasoning": true,
          "tool_call": true,
        },
        "google/gemini-3.5-flash-extra-low": {
          "name": "Gemini 3.5 Flash (Extra Low)",
          "reasoning": true,
          "tool_call": true,
        },
        "google/gemini-3.5-flash-low": {
          "name": "Gemini 3.5 Flash (Low)",
          "reasoning": true,
          "tool_call": true,
        },
        "google/gemini-3.1-pro-low": {
          "name": "Gemini 3.1 Pro (Low)",
          "reasoning": true,
          "tool_call": true,
        },
        "google/gemini-pro-agent": {
          "name": "Gemini Pro Agent",
          "reasoning": true,
          "tool_call": true,
        }
      }
    }
  },
  "plugin": ["opencode-goal-plugin"],
  "command": {
    "goal": {
      "description": "Set a session-scoped goal and auto-continue until complete.",
      "template": "$ARGUMENTS",
      "agent": "build"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "oauth": {}
    }
  }
}
